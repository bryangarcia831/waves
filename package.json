{
  "name": "waves",
  "author": "waves",
  "version": "1.0.1",
  "keywords": [
    "pebble-app"
  ],
  "pebble": {
    "sdkVersion": "3",
    "displayName": "Waves",
    "uuid": "6DE6CF3A-57CD-47BD-B40D-229E8A481D99",
    "targetPlatforms": [
      "emery"
    ],
    "watchapp": {
      "watchface": true
    },
    "enableMultiJS": true,
    "capabilities": [],
    "messageKeys": [
      "USE_24H",
      "DARK_MODE",
      "DATE_FMT",
      "TIDE_STATION"
    ],
    "dependencies": {
      "pebble-clay": "*"
    },
    "resources": {
      "media": [
        {
          "type": "font",
          "name": "FONT_TIME_48",
          "file": "fonts/DSEG7Classic-Regular.ttf",
          "characterRegex": "[0-9:AMP ]",
          "compatibility": "2.7"
        },
        {
          "type": "font",
          "name": "FONT_DATE_24",
          "file": "fonts/DSEG14Classic-Regular.ttf",
          "characterRegex": "[A-Z0-9/ \\-]",
          "compatibility": "2.7"
        },
        {
          "type": "font",
          "name": "FONT_ILLUM_11",
          "file": "fonts/ArialNarrowBoldItalic.ttf",
          "characterRegex": "[A-Za-z ]",
          "compatibility": "2.7"
        }
      ]
    }
  },
  "dependencies": {
    "pebble-clay": "^1.0.4"
  }
}
